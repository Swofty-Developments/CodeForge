{
  "$schema": "https://raw.githubusercontent.com/nicegui/nicegui/main/nicegui/templates/tauri.conf.json",
  "productName": "CodeForge",
  "identifier": "com.codeforge.app",
  "build": {
    "devUrl": "http://localhost:5173",
    "frontendDist": "./frontend/dist",
    "beforeDevCommand": "",
    "beforeBuildCommand": {
      "script": "npm install && npm run build",
      "cwd": "./frontend"
    }
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "CodeForge",
        "width": 1200,
        "height": 800,
        "center": true,
        "resizable": true,
        "minWidth": 800,
        "minHeight": 500
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": ["icons/32x32.png", "icons/icon.png", "icons/icon.ico"]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IENBMkUyM0ZBMTFDQTY2RUYKUldUdlpzb1IraU11eXJtT0NTVDIwY2UwdWNKQm5tRGwrelROdUh3TXgwalUxUm5tMnQ5T2ZVbVkK",
      "endpoints": [
        "https://github.com/Swofty-Developments/CodeForge/releases/latest/download/latest.json"
      ]
    }
  }
}
