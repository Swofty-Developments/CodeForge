    "--bg-user-bubble": "#1c2128",
    "--bg-hover": "rgba(255, 255, 255, 0.04)",
    "--text": "#e6edf3",
    "--text-secondary": "#8b949e",
    "--text-tertiary": "#6e7681",
    "--primary": "#58a6ff",
    "--primary-glow": "rgba(88, 166, 255, 0.2)",
    "--primary-muted": "#388bfd",
    "--green": "#3fb950",
    "--red": "#f85149",
    "--amber": "#d29922",
    "--sky": "#79c0ff",
    "--purple": "#bc8cff",
