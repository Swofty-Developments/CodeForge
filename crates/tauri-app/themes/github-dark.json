{
  "id": "github-dark",
  "name": "GitHub Dark",
  "description": "GitHub's official dark theme color scheme",
  "preview": ["#0d1117", "#161b22", "#58a6ff", "#3fb950"],
  "vars": {
    "--bg-base": "#0d1117",
    "--bg-card": "#161b22",
    "--bg-surface": "#161b22",
